{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Jupyter Notebook",
      "runtimeExecutable": "jupyter",
      "runtimeArgs": ["notebook", "--no-browser", "--port=8888"],
      "port": 8888
    },
    {
      "name": "TensorBoard",
      "runtimeExecutable": "tensorboard",
      "runtimeArgs": ["--logdir", "./logs", "--port", "6006"],
      "port": 6006
    },
    {
      "name": "2D Arm GUI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "rl_armMotion.two_d.gui.app"],
      "port": 0
    },
    {
      "name": "3D Arm GUI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "rl_armMotion.three_d.gui.app_3d"],
      "port": 0
    },
    {
      "name": "2D Training GUI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "rl_armMotion.two_d.gui.training_gui"],
      "port": 0
    },
    {
      "name": "3D Training GUI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "rl_armMotion.three_d.gui.training_gui"],
      "port": 0
    }
  ]
}
